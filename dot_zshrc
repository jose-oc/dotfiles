export EDITOR="nvim"
export VISUAL="nvim"

# Optional PATH additions
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Additional completion paths
if (( ${+commands[kubectx]} )); then
  fpath=($(brew --prefix kubectx)/share/zsh/site-functions $fpath)
fi

# zsh completion
autoload -Uz compinit bashcompinit
compinit
bashcompinit

# Word style
autoload -U select-word-style
select-word-style bash

# Word navigation
bindkey "^[b" backward-word
bindkey "^[f" forward-word

# Alt + Left / Right for terminals that send CSI sequences
bindkey "^[[1;3D" backward-word
bindkey "^[[1;3C" forward-word

# Home / End
bindkey "^[[H" beginning-of-line
bindkey "^[[F" end-of-line
bindkey "^[[1~" beginning-of-line
bindkey "^[[4~" end-of-line
bindkey "^[[7~" beginning-of-line
bindkey "^[[8~" end-of-line

# Alt + Backspace
bindkey '^[^?' backward-kill-word
bindkey '^[\x7f' backward-kill-word

# zoxide
if (( ${+commands[zoxide]} )); then
  eval "$(zoxide init zsh)"
fi

# fzf
if (( ${+commands[fzf]} )); then
  source <(fzf --zsh)
fi

if (( ${+commands[fd]} )); then
  export FZF_DEFAULT_COMMAND='fd --type file --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type directory --hidden --follow --exclude .git'
fi

if (( ${+commands[bat]} )); then
  export FZF_CTRL_T_OPTS='--preview "bat --color=always --style=numbers --line-range=:300 {}"'
fi

if (( ${+commands[eza]} )); then
  alias ls='eza --icons'
  alias ll='eza --long --header --git --icons'
  alias la='eza --long --header --git --icons --all'
  alias tree='eza --tree --level=3 --icons'
fi

if (( ${+commands[rg]} )); then
  alias rgf='rg --files'
  alias rgh='rg --hidden --glob "!.git"'
fi

if (( ${+commands[kubectl]} )); then
  source <(kubectl completion zsh)
fi

if (( ${+commands[direnv]} )); then
  eval "$(direnv hook zsh)"
fi

[ -f "$HOME/.config/zsh/functions.zsh" ] && source "$HOME/.config/zsh/functions.zsh"
[ -f "$HOME/.config/zsh/aliases.zsh" ] && source "$HOME/.config/zsh/aliases.zsh"

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000

setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS
setopt HIST_EXPIRE_DUPS_FIRST

if (( ${+commands[starship]} )); then
  eval "$(starship init zsh)"
fi
