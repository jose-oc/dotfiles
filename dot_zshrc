# Word navigation
bindkey "^[b" backward-word
bindkey "^[f" forward-word

# Arrow-based word navigation (iTerm sends these)
bindkey "^[[1;3D" backward-word
bindkey "^[[1;3C" forward-word


export EDITOR="nvim"
export VISUAL="nvim"


# zsh completion
autoload -Uz compinit bashcompinit
compinit
bashcompinit


# ---- Core CLI integrations ----

# zoxide: smarter directory jumping
if (( ${+commands[zoxide]} )); then
  eval "$(zoxide init zsh)"
fi

# fzf: key bindings and fuzzy completion
# fzf 0.48.0+ supports `fzf --zsh`
if (( ${+commands[fzf]} )); then
  source <(fzf --zsh)
fi

# Better file source for fzf:
# - use fd instead of the default file walker
# - include hidden files
# - follow symlinks
# - ignore .git
if (( ${+commands[fd]} )); then
  export FZF_DEFAULT_COMMAND='fd --type file --hidden --follow --exclude .git'
  export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
  export FZF_ALT_C_COMMAND='fd --type directory --hidden --follow --exclude .git'
fi

# Better preview inside fzf using bat
if (( ${+commands[bat]} )); then
  export FZF_CTRL_T_OPTS='--preview "bat --color=always --style=numbers --line-range=:300 {}"'
fi

# Better defaults for common commands
if (( ${+commands[eza]} )); then
  alias ls='eza --icons'
  alias ll='eza --long --header --git --icons'
  alias la='eza --long --header --git --icons --all'
  alias tree='eza --tree --level=3 --icons'
fi

# Safer bat alias:
# use `cat` normally if you prefer, or uncomment the alias below
# alias cat='bat --paging=never'

# Common ripgrep convenience aliases
if (( ${+commands[rg]} )); then
  alias rgf='rg --files'
  alias rgh='rg --hidden --glob "!.git"'
fi

# Prepare kubectl completion for later.
# This does nothing until kubectl is installed.
if (( ${+commands[kubectl]} )); then
  source <(kubectl completion zsh)
fi

# kubectx / kubens completion
if (( ${+commands[kubectx]} )); then
  fpath=($(brew --prefix kubectx)/share/zsh/site-functions $fpath)
fi

if (( ${+commands[direnv]} )); then
  eval "$(direnv hook zsh)"
fi


# ---- Aliases ----

alias md="mkdir -p"

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."

alias k="kubectl"
alias kgp="kubectl get pods"
alias kgs="kubectl get services"
alias kgd="kubectl get deployments"
alias kd="kubectl describe"
alias kl="kubectl logs"

# Safer defaults I actually recommend using explicitly
alias kctx="kubectl config current-context"
alias kns="kubectl config view --minify --output 'jsonpath={..namespace}' ; echo"

# Optional: open k9s in readonly mode by default
alias k9sr="k9s --readonly"

# ---- Aliases end ----

# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/jose/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/jose/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/jose/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/jose/google-cloud-sdk/completion.zsh.inc'; fi

eval "$(starship init zsh)"

